#include <SFML/Graphics.hpp>
#include <iostream>
#include <windows.h>

enum class Direction
{
	up,
	down,
	left,
	right
};

int main()
{
	sf::RenderWindow window(sf::VideoMode({400, 400}), "Snake");
	sf::RectangleShape shape({10.f, 10.f});
	shape.setFillColor(sf::Color::Green);

	float x{390.f};
	float y{390.f};

	Direction currDirection{Direction::up};

	shape.setPosition({x, y});

	while (window.isOpen())
	{
		while (const std::optional event = window.pollEvent())
		{
			shape.setPosition({x, y});

			if (y > 0.f && currDirection != Direction::up && sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Up))
				currDirection = Direction::up;

			if (y < 390.f && currDirection != Direction::down && sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Down))
				currDirection = Direction::down;

			if (x > 0.f && currDirection != Direction::left && sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Left))
				currDirection = Direction::left;

			if (x < 390.f && currDirection != Direction::right && sf::Keyboard::isKeyPressed(sf::Keyboard::Key::Right))
				currDirection = Direction::right;

			switch (currDirection)
			{
				case Direction::up:
					y -= 10;
					std::cout << "(" << x << ", " << y << ")\n";
					break;
				case Direction::down:
					y += 10;
					std::cout << "(" << x << ", " << y << ")\n";
					break;
				case Direction::left:
					x -= 10;
					std::cout << "(" << x << ", " << y << ")\n";
					break;
				case Direction::right:
					x += 10;
					std::cout << "(" << x << ", " << y << ")\n";
					break;
			}

			if (event->is<sf::Event::Closed>())
				window.close();
		}

		window.clear();
		window.draw(shape);
		window.display();
	}
}
